# Supabase (EU Frankfurt — added in Story 1.2)
# Keys found in: Supabase Dashboard → Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=          # Project URL
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY= # Publishable key (sb_publishable_xxx) — safe for browser with RLS enabled
SUPABASE_SECRET_KEY=               # Secret key — server-only, bypasses RLS, never expose to client
DATABASE_URL=                      # Postgres connection string for Drizzle ORM — found under Settings → Database
SYSTEM_USER_ID=                    # UUID of locked system user for cold start deck (set in Story 1.2)

# Azure OpenAI (Sweden Central — EU Data Zone)
# Each model is a separate Azure resource — found in Azure Portal → AI Foundry → resource → Keys and Endpoint
# Endpoint format: https://{resource}.cognitiveservices.azure.com/openai  (no /deployments suffix)
AZURE_OPENAI_ENDPOINT_FAST=        # e.g. https://my-resource.cognitiveservices.azure.com/openai
AZURE_OPENAI_API_KEY_FAST=
AZURE_OPENAI_DEPLOYMENT_FAST=      # deployment name as shown in AI Foundry (e.g. gpt-4.1-mini)

AZURE_OPENAI_ENDPOINT_LARGE=
AZURE_OPENAI_API_KEY_LARGE=
AZURE_OPENAI_DEPLOYMENT_LARGE=     # e.g. gpt-4.1

AZURE_OPENAI_ENDPOINT_FALLBACK=
AZURE_OPENAI_API_KEY_FALLBACK=
AZURE_OPENAI_DEPLOYMENT_FALLBACK=  # e.g. gpt-4o

# Stripe (added in Epic 7)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend (added in Epic 8)
RESEND_API_KEY=

# Upstash Redis (rate limiting — added in Story 1.2+)
UPSTASH_REDIS_REST_URL=    # from Upstash Console → Redis → REST API
UPSTASH_REDIS_REST_TOKEN=  # from Upstash Console → Redis → REST API

# Sentry (added in Story 1.1)
NEXT_PUBLIC_SENTRY_DSN=    # client-side DSN (must have NEXT_PUBLIC_ prefix for browser bundle)
SENTRY_DSN=                # server-side DSN (same value as NEXT_PUBLIC_SENTRY_DSN)
SENTRY_AUTH_TOKEN=         # for source map upload in CI
SENTRY_ORG=                # Sentry organization slug
SENTRY_PROJECT=            # Sentry project slug

# App
NEXT_PUBLIC_APP_URL=       # e.g. http://localhost:3000 locally, https://flashcards.app in prod

# Cold start deck ID — optional override (runtime getSystemDeck() lookup is preferred)
# COLD_START_DECK_ID=
